FLASK_ENV=development
SECRET_KEY=change-me-in-production

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=yourpassword
DB_NAME=cloudgame

JWT_SECRET_KEY=change-jwt-secret-in-production
JWT_ACCESS_TOKEN_EXPIRES=3600

ADMIN_PASSWORD=Admin1234!

# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=ap-northeast-2
EC2_AMI_ID=ami-xxxxxxxxxxxxxxxx
EC2_INSTANCE_TYPE=t2.micro
EC2_KEY_NAME=your-key-pair-name
EC2_SECURITY_GROUP_ID=sg-xxxxxxxxxxxxxxxx
EC2_SUBNET_ID=subnet-xxxxxxxxxxxxxxxx

AGENT_PORT=7000
# LOADCLIENT_DIR=/absolute/path/to/backend/loadagent

# 로드 에이전트 → 백엔드 이벤트 로그 전송 설정
# EC2 인스턴스에서 백엔드 서버로 접근 가능한 내부 URL (Private IP 또는 내부 DNS)
BACKEND_INTERNAL_URL=http://10.0.0.1:5000
INTERNAL_AGENT_TOKEN=change-this-secret-token
